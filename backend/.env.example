# Copy this file to backend/.env and replace the placeholder locally.
# Never commit backend/.env or paste a real key into source code.
OPENAI_API_KEY=replace_with_your_openai_api_key

# Agent model assignments for the prototype.
OPENAI_MODEL_MASTER=gpt-realtime-1.5
OPENAI_MODEL_AGENTS=gpt-5.1

# Required only for the Research Agent's read-only Tavily remote MCP access.
TAVILY_API_KEY=replace_with_your_tavily_api_key
# Optional local runtime data override. Default: backend/data/research.sqlite3
# KINDRED_RESEARCH_DB_PATH=backend/data/research.sqlite3

# One stable warm English voice for the browser Care Hub.
OPENAI_SPEECH_MODEL=tts-1-hd
OPENAI_SPEECH_VOICE=nova

# Keep false only for automated/offline tests. The React frontend runtime should use true.
KINDRED_ENABLE_LLM=true

# Optional observability. Enable only after adding your Langfuse project keys.
LANGFUSE_PUBLIC_KEY=pk-lf-replace_me
LANGFUSE_SECRET_KEY=sk-lf-replace_me
LANGFUSE_BASE_URL=https://cloud.langfuse.com
KINDRED_ENVIRONMENT=development

# Optional: point the MCP clients at independently running HTTP MCP servers.
# If omitted, the prototype uses FastMCP's in-process transport for local testing.
# KINDRED_MCP_SECURITY_URL=http://127.0.0.1:8001/mcp/
# KINDRED_MCP_HEALTH_URL=http://127.0.0.1:8002/mcp/
# KINDRED_MCP_INVENTORY_URL=http://127.0.0.1:8003/mcp/
